                    "speaker": "Айлан",
                    "textTuvan": "Эртен сен кандыг кылыр сен?",
                    "textRu": "Утром что ты делаешь?"
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Мен эртен турар мен болгаш чуур мен.",
                    "textRu": "Утром я встаю и умываюсь."
                },
                {
                    "speaker": "Айлан",
                    "textTuvan": "А хүн ортузунда?",
                    "textRu": "А днем?"
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Хүн мен ажылдаап тур мен. Кежээ мен амыраап тур мен.",
                    "textRu": "Днем я работаю. Вечером я отдыхаю."
                }
            ],
