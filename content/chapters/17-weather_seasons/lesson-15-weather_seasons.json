                {
                    "speaker": "Айлан",
                    "textTuvan": "Бүгү агаар кандыг-дыр?",
                    "textRu": "Сегодня какая погода?"
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Бүгү соок бооп тур. Кар чаар.",
                    "textRu": "Сегодня холодно. Будет снег."
                },
                {
                    "speaker": "Айлан",
                    "textTuvan": "Эртен база соок бе?",
                    "textRu": "Завтра тоже холодно?"
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Чок, эртен изиг бооп тур. Хүн үнүп тур.",
                    "textRu": "Нет, завтра будет жарко. Светит солнце."
                }
            ],
