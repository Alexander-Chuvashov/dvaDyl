            "dialogueLines": [
                {
                    "speaker": "Айлан",
                    "textTuvan": "Хостуг үеңде чүү кылыр сен?",
                    "textRu": "В свободное время что ты делаешь?"
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Мен номчулганы өөрээр мен. А сен?",
                    "textRu": "Я люблю чтение. А ты?"
                },
                {
                    "speaker": "Айлан",
                    "textTuvan": "Мен хөгжүм өөрээвес. Мен спорт кылыр мен.",
                    "textRu": "Я не люблю музыку. Я занимаюсь спортом."
                },
                {
                    "speaker": "Чаяна",
                    "textTuvan": "Эртен бис оюннар ойнаар бис.",
                    "textRu": "Завтра мы будем играть в игры."
                }
            ],
